{
  "version": 2,
  "outputDirectory": "public",
  "routes": [
    { "src": "/record", "dest": "/record.html" },
    { "src": "/record.html", "dest": "/record.html" },
    { "src": "/api/track-record", "dest": "/api/track-record.js" },
    { "src": "/api/odds", "dest": "/api/odds.js" },
    { "src": "/api/checkout", "dest": "/api/checkout.js" },
    { "src": "/api/scores", "dest": "/api/scores.js" },
    { "src": "/re-config.js", "dest": "/re-config.js" },
    { "src": "/re-teams.js", "dest": "/re-teams.js" },
    { "src": "/re-players.js", "dest": "/re-players.js" },
    { "src": "/re-models.js", "dest": "/re-models.js" },
    { "src": "/re-api.js", "dest": "/re-api.js" },
    { "src": "/re-ui.js", "dest": "/re-ui.js" },
    { "src": "/re-sport-nfl.js", "dest": "/re-sport-nfl.js" },
    { "src": "/re-sport-nba.js", "dest": "/re-sport-nba.js" },
    { "src": "/re-sport-mlb.js", "dest": "/re-sport-mlb.js" },
    { "src": "/re-sport-nhl.js", "dest": "/re-sport-nhl.js" },
    { "src": "/re-sport-soccer.js", "dest": "/re-sport-soccer.js" },
    { "src": "/re-sport-other.js", "dest": "/re-sport-other.js" },
    { "src": "/re-dashboard.js", "dest": "/re-dashboard.js" },
    { "src": "/re-calibration.js", "dest": "/re-calibration.js" },
    { "src": "/re-app.js", "dest": "/re-app.js" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/(.*)", "dest": "/app.html" }
  ],
  "crons": [
    {
      "path": "/api/email",
      "schedule": "0 15 * * *"
    }
  ]
}
